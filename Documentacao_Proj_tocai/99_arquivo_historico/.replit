modules = ["vue-node-20", "nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Server"

[[workflows.workflow]]
name = "Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 41917
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "npm --prefix backend run start & npx serve frontend/dist -p 5000"]
build = ["npm", "--prefix", "frontend", "run", "build"]
