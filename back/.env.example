# =============================================================
# TrocaAi Backend — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o arquivo .env — ele já está no .gitignore.
# =============================================================

# ---- Servidor ----
PORT=3000
NODE_ENV=development   # development | production | test

# ---- JWT ----
# Gere um secret seguro: node -e "require('crypto').randomBytes(64).toString('hex')|clip"
JWT_SECRET=COLOQUE_AQUI_UM_SECRET_ALEATORIO_DE_64_CHARS
JWT_EXPIRES_IN=15m

# ---- Refresh Token ----
REFRESH_TOKEN_SECRET=COLOQUE_AQUI_OUTRO_SECRET_ALEATORIO_DIFERENTE_64_CHARS
REFRESH_TOKEN_EXPIRES_IN=7d

# ---- Banco de dados ----
# Para SQLite (dev local):
DB_TYPE=sqlite
DB_DATABASE=database.sqlite

# Para MySQL/MariaDB (produção):
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=trocaai
# DB_PASS=senha_segura_aqui
# DB_NAME=trocaai_prod

# ---- CORS ----
# Separe múltiplas origens por vírgula
FRONTEND_URL=http://localhost:5174

# ---- Web Push (VAPID) ----
# Gere as chaves: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=COLOQUE_AQUI_A_CHAVE_VAPID_PUBLICA
VAPID_PRIVATE_KEY=COLOQUE_AQUI_A_CHAVE_VAPID_PRIVADA
VAPID_SUBJECT=mailto:admin@trocaai.com.br

# ---- Logs ----
LOG_LEVEL=info   # error | warn | info | debug
